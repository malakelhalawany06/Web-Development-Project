<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>LoomHub — Admin Dashboard</title>
    <script src="/js/admin-users.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/project web.css">    
<link rel="stylesheet" href="/css/admin-dashboard.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <div class="layout">
        <%- include('partials/sidebar-admin', { activePage: 'dashboard' }) %>

        <div class="main">
            <%- include('partials/topbar', { user: locals.user, userRole: userRole }) %>

            <div class="admin-dashboard-container">

                <div class="welcome-banner">
                    <div class="welcome-text">
                        <h1>Welcome back, <%= user.firstName || 'Admin' %> 👋</h1>
                        <p class="welcome-subtitle">Here's what's happening across LoomHub today.</p>
                    </div>
                </div>

                <div class="stats-grid-clean">
                    
                    <div class="stat-card">
                        <div class="stat-icon blue">
                            <i class="fas fa-user-graduate"></i>
                        </div>
                        <div class="stat-info">
                            <span class="stat-label">Total Students</span>
                            <span class="stat-value"><%= locals.stats ? stats.totalStudents : 6 %></span>
                        </div>
                       <div class="stat-change positive">
    <i class="fas fa-arrow-up"></i> +<%= locals.stats ? stats.newStudentsThisMonth : 0 %> this month
</div>
                    </div>

                    <div class="stat-card">
                        <div class="stat-icon green">
                            <i class="fas fa-chalkboard-user"></i>
                        </div>
                        <div class="stat-info">
                            <span class="stat-label">Total Instructors</span>
                            <span class="stat-value"><%= locals.stats ? stats.totalInstructors : 4 %></span>
                        </div>
                       <div class="stat-change positive">
    <i class="fas fa-arrow-up"></i> +<%= locals.stats ? stats.newInstructorsThisMonth : 0 %> this month
</div>
                    </div>

                    <div class="stat-card">
                        <div class="stat-icon orange">
                            <i class="fas fa-circle-dot"></i>
                        </div>
                        <div class="stat-info">
                            <span class="stat-label">Active Today</span>
                            <span class="stat-value"><%= locals.stats ? stats.activeToday : 0 %></span>
                        </div>
                        <div class="stat-change">
                            <i class="fas fa-clock"></i> Last 24h
                        </div>
                    </div>
                    
                </div>

                <div class="quick-actions-title">Quick Actions</div>
                
               
                    <a href="/admin/analytics" class="custom-action-btn">
                        <i class="fas fa-chart-pie"></i>
                        <span>Reports</span>
                    </a>
                    <a href="/admin/users" class="custom-action-btn">
                        <i class="fas fa-shield-alt"></i>
                        <span>Permissions</span>
                    </a>
                </div>

            </div>
        </div>
    </div>

    <script src="/js/admin-dashboard.js"></script>
</body>
</html>
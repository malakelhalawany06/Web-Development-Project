<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>LoomHub — Admin Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/project web.css">
    <link rel="stylesheet" href="/css/admin-dashboard.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <div class="layout">
        <%- include('partials/sidebar-admin', { activePage: 'dashboard' }) %>

        <div class="main">
            <%- include('partials/topbar', { user: locals.user, userRole: userRole }) %>

            <main class="main-content">

                <div class="welcome-banner">
                    <div class="welcome-text">
                        <h1>Welcome back, <%= user.firstName || 'Admin' %> 👋</h1>
                        <p>Here's what's happening across LoomHub today.</p>
                    </div>
                    <div class="welcome-date">
                        <i class="fas fa-calendar-alt"></i>
                        <span id="currentDate"></span>
                    </div>
                </div>

                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-icon blue">
                            <i class="fas fa-user-graduate"></i>
                        </div>
                        <div class="stat-info">
                            <span class="stat-label">Total Students</span>
                            <span class="stat-value"><%= locals.stats ? stats.totalStudents : 0 %></span>
                        </div>
                        <div class="stat-change positive">
                            <i class="fas fa-arrow-up"></i> +42 this month
                        </div>
                    </div>

                    <div class="stat-card">
                        <div class="stat-icon green">
                            <i class="fas fa-chalkboard-user"></i>
                        </div>
                        <div class="stat-info">
                            <span class="stat-label">Total Instructors</span>
                            <span class="stat-value"><%= locals.stats ? stats.totalInstructors : 0 %></span>
                        </div>
                        <div class="stat-change positive">
                            <i class="fas fa-arrow-up"></i> +5 this month
                        </div>
                    </div>

                    <div class="stat-card">
                        <div class="stat-icon purple">
                            <i class="fas fa-book-open"></i>
                        </div>
                        <div class="stat-info">
                            <span class="stat-label">Total Courses</span>
                            <span class="stat-value"><%= locals.stats ? stats.totalCourses : 0 %></span>
                        </div>
                        <div class="stat-change positive">
                            <i class="fas fa-arrow-up"></i> Active
                        </div>
                    </div>

                    <div class="stat-card">
                        <div class="stat-icon orange">
                            <i class="fas fa-circle-dot"></i>
                        </div>
                        <div class="stat-info">
                            <span class="stat-label">Active Today</span>
                            <span class="stat-value"><%= locals.stats ? stats.activeToday : 0 %></span>
                        </div>
                        <div class="stat-change">
                            <i class="fas fa-clock"></i> Last 24h
                        </div>
                    </div>

                    <div class="stat-card">
                        <div class="stat-icon teal">
                            <i class="fas fa-clipboard-check"></i>
                        </div>
                        <div class="stat-info">
                            <span class="stat-label">Assignments Today</span>
                            <span class="stat-value"><%= locals.stats ? stats.assignmentsToday : 0 %></span>
                        </div>
                        <div class="stat-change positive">
                            <i class="fas fa-arrow-up"></i> Submitted
                        </div>
                    </div>

                    <div class="stat-card">
                        <div class="stat-icon red">
                            <i class="fas fa-hourglass-half"></i>
                        </div>
                        <div class="stat-info">
                            <span class="stat-label">Pending Grading</span>
                            <span class="stat-value"><%= locals.stats ? stats.pendingGrading : 0 %></span>
                        </div>
                        <div class="stat-change negative">
                            <i class="fas fa-exclamation-circle"></i> Needs attention
                        </div>
                    </div>
                </div>

                <div class="section-title">Quick Actions</div>
                <div class="quick-actions">
                    <a href="/admin/analytics" class="action-card">
                        <i class="fas fa-chart-line"></i>
                        <span>Analytics</span>
                    </a>
                    <a href="/admin/users" class="action-card">
                        <i class="fas fa-users-cog"></i>
                        <span>User Management</span>
                    </a>
                    <a href="/admin/analytics" class="action-card">
                        <i class="fas fa-chart-pie"></i>
                        <span>Reports</span>
                    </a>
                    <a href="/admin/users" class="action-card">
                        <i class="fas fa-shield-alt"></i>
                        <span>Permissions</span>
                    </a>
                </div>

            </main>
        </div>
    </div>

    <script src="/js/admin-dashboard.js"></script>
</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>LoomHub — Student Platform</title>
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/project web.css">
  <script src="/js/users.js"></script>
  <%#<script src="/js/personalInfo.js"></script>%>
  <script src="project web.js"></script>
  <script src="/js/project web trial 1.js"></script>
</head>
<body class="layout">

  <%- include('partials/sidebar-admin') %>

  <div class="main">

    <%- include('partials/topbar') %>

    <div class="content">

      <div class="stats-grid" style="grid-template-columns: repeat(3, 1fr);">
        
        <div class="stat-card">
          <div class="stat-icon">👥</div>
          <div class="stat-val" id="totalStudents">1,248</div>
          <div class="stat-label">Total Students</div>
          <div class="stat-change">↑ +42 this month</div>
        </div>

        <div class="stat-card">
          <div class="stat-icon">🟢</div>
          <div class="stat-val" id="activeToday">892</div>
          <div class="stat-label">Active Students Today</div>
          <div class="stat-change">↑ 15% higher than average</div>
        </div>

        <div class="stat-card">
          <div class="stat-icon">📚</div>
          <div class="stat-val" id="totalCourses">64</div>
          <div class="stat-label">Total Courses</div>
          <div class="stat-change">↑ +3 new this semester</div>
        </div>

        <div class="stat-card">
          <div class="stat-icon">📈</div>
          <div class="stat-val" id="completionRate">87%</div>
          <div class="stat-label">Course Completion Rate</div>
          <div class="stat-change">↑ +2.4% vs last year</div>
        </div>

        <div class="stat-card">
          <div class="stat-icon">📝</div>
          <div class="stat-val" id="assignmentsToday">3,405</div>
          <div class="stat-label">Assignments Submitted Today</div>
          <div class="stat-change warn" id="pendingGrading">840 pending grading</div>
        </div>

        <div class="stat-card">
          <div class="stat-icon">🎯</div>
          <div class="stat-val" id="avgScore">82.4</div>
          <div class="stat-label">Average Student Score</div>
          <div class="stat-change">↑ +1.2 points overall</div>
        </div>

      </div>

      <div class="main-grid" style="grid-template-columns: 1fr;">

        <div class="card">
          <div class="card-header">
            <span class="card-title">⚡ Quick Actions</span>
          </div>
          
          <div style="display: flex; gap: 12px; flex-wrap: wrap;">
            <button class="btn btn-primary" onclick="window.location.href='/admin/courses/new'">
              ➕ Create Course
            </button>
            <button class="btn btn-ghost" onclick="window.location.href='/admin/instructors/add'">
              👨‍🏫 Add Instructor
            </button>
            <button class="btn btn-ghost" onclick="window.location.href='/admin/announcements/new'">
              📢 Send Announcement
            </button>
            <button class="btn btn-ghost" onclick="window.location.href='/admin/reports'">
              📊 Export Reports
            </button>
            <button class="btn btn-ghost" onclick="window.location.href='/admin/users'">
              👥 Manage Users
            </button>
          </div>
        </div>

        <div class="card" style="margin-top: 1.25rem;">
          <div class="card-header">
            <span class="card-title">📋 System Activity Logging</span>
            <button class="btn btn-ghost" style="padding:4px 10px;font-size:12px;">View All</button>
          </div>

          <table class="admin-table">
            <thead>
              <tr>
                <th>Event</th>
                <th>User</th>
                <th>Time</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>New Course Created: Network Security</td>
                <td>Dr. Sarah Connor</td>
                <td>10 mins ago</td>
                <td><span class="status-pill pill-green">Success</span></td>
              </tr>
              <tr>
                <td>Bulk User Import</td>
                <td>System Admin</td>
                <td>1 hour ago</td>
                <td><span class="status-pill pill-green">Completed</span></td>
              </tr>
              <tr>
                <td>Failed Login Attempt</td>
                <td>Unknown (IP: 192.168.1.1)</td>
                <td>2 hours ago</td>
                <td><span class="status-pill pill-warn">Flagged</span></td>
              </tr>
            </tbody>
          </table>
        </div>

      </div>
    </div>
  </div>
</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>LoomHub — User Management</title>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/project web.css">
    <link rel="stylesheet" href="/css/admin-users.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <div class="layout">
        <%- include('partials/sidebar-admin', { activePage: 'users' }) %>

        <div class="main">
            <%- include('partials/topbar', { user: locals.user, userRole: userRole }) %>

            <div class="content">

                <!-- Page Header -->
                <div class="page-header">
                    <div>
                        <h1>User Management</h1>
                        <p>Manage all students, instructors, and admins</p>
                    </div>
                    <div class="header-stats">
                        <span class="um-badge"><i class="fas fa-users"></i> <%= locals.users ? locals.users.length : 0 %> Total</span>
                    </div>
                </div>

                <!-- Filter Tabs -->
                <div class="filter-tabs">
                    <button class="tab-btn active" data-filter="all">All Users</button>
                    <button class="tab-btn" data-filter="student">Students</button>
                    <button class="tab-btn" data-filter="instructor">Instructors</button>
                    <button class="tab-btn" data-filter="admin">Admins</button>
                </div>

                <!-- Search Bar -->
                <div class="um-search-bar">
                    <i class="fas fa-search"></i>
                    <input type="text" id="userSearch" placeholder="Search by name, email, or role..." />
                </div>

                <!-- Users Table -->
                <div class="table-wrapper">
                    <table class="users-table" id="usersTable">
                        <thead>
                            <tr>
                                <th>User</th>
                                <th>Email / Username</th>
                                <th>Role</th>
                                <th>Uni Year / Major</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (locals.users && locals.users.length > 0) { %>
                                <% users.forEach(u => { %>
                                    <tr data-id="<%= u._id %>" data-collection="<%= u.collection %>" data-role="<%= u.role %>">
                                        <td class="user-cell">
                                            <div class="user-avatar">
                                                <% if (u.profile_picture) { %>
                                                    <img src="<%= u.profile_picture %>" alt="avatar" />
                                                <% } else { %>
                                                    <div class="avatar-placeholder">
                                                        <%= (u.firstName || u.name || '?')[0].toUpperCase() %>
                                                    </div>
                                                <% } %>
                                            </div>
                                            <div class="user-name">
                                                <%= u.firstName ? `${u.firstName} ${u.lastName || ''}` : (u.name || 'N/A') %>
                                            </div>
                                        </td>
                                        <td><%= u.email || u.username || 'N/A' %></td>
                                        <td>
                                            <span class="role-badge role-<%= u.role %>">
                                                <i class="fas <%= u.role === 'student' ? 'fa-graduation-cap' : u.role === 'instructor' ? 'fa-chalkboard-user' : 'fa-shield-alt' %>"></i>
                                                <%= u.role %>
                                            </span>
                                        </td>
                                        <td>
                                            <% if (u.role === 'student') { %>
                                                Year <%= u.year || u.academic_year || 'N/A' %> · <%= u.major || 'N/A' %>
                                            <% } else { %>
                                                —
                                            <% } %>
                                        </td>
                                        <td>
                                            <span class="status-badge status-<%= u.status || 'active' %>">
                                                <i class="fas fa-circle"></i>
                                                <%= u.status || 'active' %>
                                            </span>
                                        </td>
                                        <td class="actions-cell">
                                            <button class="action-btn green"   onclick="changeStatus(this,'active')"    title="Activate"><i class="fas fa-check-circle"></i></button>
                                            <button class="action-btn yellow"  onclick="changeStatus(this,'suspended')" title="Suspend"><i class="fas fa-pause-circle"></i></button>
                                            <button class="action-btn red"     onclick="changeStatus(this,'banned')"    title="Ban"><i class="fas fa-ban"></i></button>
                                            <button class="action-btn red"     onclick="deleteUser(this)"               title="Delete"><i class="fas fa-trash-alt"></i></button>
                                            <button class="action-btn blue"    onclick="resetPassword(this)"            title="Reset Password"><i class="fas fa-key"></i></button>
                                            <button class="action-btn blue"    onclick="forceReset(this)"               title="Force reset on next login"><i class="fas fa-sync-alt"></i></button>
                                            <button class="action-btn gray"    onclick="logoutAll(this)"                title="Logout all devices"><i class="fas fa-sign-out-alt"></i></button>
                                            <button class="action-btn yellow"  onclick="showWarningModal(this)"         title="Send warning"><i class="fas fa-exclamation-triangle"></i></button>
                                            <button class="action-btn gray"    onclick="toggleRestrict(this)"           title="Restrict posting"><i class="fas fa-lock"></i></button>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="6" class="empty-state">
                                        <i class="fas fa-users-slash"></i>
                                        <p>No users found.</p>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>

            </div><!-- end .content -->
        </div><!-- end .main -->
    </div><!-- end .layout -->

    <!-- Warning Modal — outside .layout so it overlays everything -->
    <div id="warningModal" class="um-modal">
        <div class="um-modal-box">
            <div class="um-modal-header">
                <h3><i class="fas fa-exclamation-triangle"></i> Send Warning</h3>
                <button class="um-modal-close" onclick="closeModal()"><i class="fas fa-times"></i></button>
            </div>
            <div class="um-modal-body">
                <label>Warning Message</label>
                <textarea id="warningMsg" rows="4" placeholder="Enter your warning message..."></textarea>
            </div>
            <div class="um-modal-footer">
                <button class="btn btn-ghost" onclick="closeModal()">Cancel</button>
                <button class="btn btn-primary" onclick="sendWarning()">
                    <i class="fas fa-paper-plane"></i> Send Warning
                </button>
            </div>
        </div>
    </div>

    <script src="/js/admin-users.js"></script>
</body>
</html>

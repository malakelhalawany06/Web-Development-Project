<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>LoomHub — User Management</title>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
   <link rel="stylesheet" href="/css/admin-users.css">
    <link rel="stylesheet" href="/css/project web.css">

    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <div class="layout">
        <%- include('partials/sidebar-admin', { activePage: 'users' }) %>

        <div class="main">
            <%- include('partials/topbar', { user: locals.user, userRole: userRole }) %>

            <div class="content">

                <div class="page-header">
                    <div>
                        <h1>User Management</h1>
                        <p>Manage all students, instructors, and admins</p>
                    </div>
                    <div class="header-stats">
                        <span class="um-badge">
                            <i class="fas fa-users"></i>
                            <%= locals.users ? locals.users.length : 0 %> Total
                        </span>
                    </div>
                </div>

                <div class="filter-tabs">
                    <button class="tab-btn active" data-filter="all">All Users</button>
                    <button class="tab-btn" data-filter="student">Students</button>
                    <button class="tab-btn" data-filter="instructor">Instructors</button>
                    <button class="tab-btn" data-filter="admin">Admins</button>
                </div>

                <div class="um-search-bar">
                    <i class="fas fa-search"></i>
                    <input type="text" id="userSearch" placeholder="Search by name, email, or role..." />
                </div>

                <div class="users-grid" id="usersGrid">
                    <% if (locals.users && locals.users.length > 0) { %>
                        <% users.forEach(u => { %>
                            <div class="user-card"
                                 data-id="<%= u._id %>"
                                 data-collection="<%= u.collection %>"
                                 data-role="<%= u.role %>">

                                <div class="card-header">
                                    <div class="user-avatar">
                                        <% if (u.profile_picture) { %>
                                            <img src="<%= u.profile_picture %>" alt="avatar" />
                                        <% } else { %>
                                            <div class="avatar-placeholder bg-<%= u.role %>">
                                                <%= (u.firstName || u.name || '?')[0].toUpperCase() %>
                                            </div>
                                        <% } %>
                                    </div>
                                    <div class="user-info">
                                        <h3><%= u.firstName ? `${u.firstName} ${u.lastName || ''}` : (u.name || 'N/A') %></h3>
                                        <span class="username">@<%= u.username || u.email.split('@')[0] %></span>
                                    </div>
                                </div>

                                <div class="card-body">
                                    <div class="role-line">
                                        <i class="fas <%= u.role === 'student' ? 'fa-graduation-cap' : u.role === 'instructor' ? 'fa-chalkboard-user' : 'fa-user-shield' %> role-icon"></i>
                                        <span class="role-text"><%= u.role.charAt(0).toUpperCase() + u.role.slice(1) %></span>
                                        <i class="fas fa-shield-halved shield-icon"></i>
                                    </div>
                                    <div class="email-line">
                                        <span class="email-label">Email:</span> <%= u.email || 'N/A' %>
                                    </div>
                                </div>

                                <div class="card-footer">
                                    <div class="status-wrapper">
                                        <span class="status-label">Status</span>
                                        <span class="status-badge status-<%= (u.status || 'active').toLowerCase() %>">
                                            <i class="fas fa-circle"></i>
                                            <%= u.status ? u.status.charAt(0).toUpperCase() + u.status.slice(1) : 'Active' %>
                                        </span>
                                    </div>

                                    <%# ── Action buttons: Edit | Warn | Delete ── %>
                                    <div class="actions-wrapper">
                                        <button class="action-btn edit-btn"
                                                onclick="showEditModal(this)"
                                                title="Edit User">
                                            <i class="fas fa-pen"></i>
                                        </button>
                                        <button class="action-btn warning-btn"
                                                onclick="showWarningModal(this)"
                                                title="Send Warning">
                                            <i class="fas fa-exclamation-triangle"></i>
                                        </button>
                                        <button class="action-btn delete-btn"
                                                onclick="deleteUser(this)"
                                                title="Delete User">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </div>
                                </div>

                            </div>
                        <% }) %>
                    <% } else { %>
                        <div class="empty-state">
                            <i class="fas fa-users-slash"></i>
                            <p>No users found.</p>
                        </div>
                    <% } %>
                </div>

            </div>
        </div>
    </div>

    <%# ══════════════════════════════════════════ %>
    <%# WARNING MODAL                             %>
    <%# ══════════════════════════════════════════ %>
    <div id="warningModal" class="um-modal">
        <div class="um-modal-box">
            <div class="um-modal-header">
                <h3><i class="fas fa-exclamation-triangle"></i> Send Warning</h3>
                <button class="um-modal-close" onclick="closeWarningModal()">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="um-modal-body">
                <label>Warning Message</label>
                <textarea id="warningMsg" rows="4" placeholder="Enter your warning message..."></textarea>
            </div>
            <div class="um-modal-footer">
                <button class="btn btn-ghost" onclick="closeWarningModal()">Cancel</button>
                <button class="btn btn-primary" onclick="sendWarning()">
                    <i class="fas fa-paper-plane"></i> Send Warning
                </button>
            </div>
        </div>
    </div>

    <%# ══════════════════════════════════════════ %>
    <%# EDIT MODAL                                %>
    <%# ══════════════════════════════════════════ %>
    <div id="editModal" class="um-modal">
        <div class="um-modal-box">
            <div class="um-modal-header">
                <h3><i class="fas fa-user-pen"></i> Edit User</h3>
                <button class="um-modal-close" onclick="closeEditModal()">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="um-modal-body">
                <%# Hidden fields carry the target user's id & collection %>
                <input type="hidden" id="editUserId" />
                <input type="hidden" id="editUserCollection" />

                <div class="edit-fields">
                    <div class="edit-field-group">
                        <label for="editFirstName">First Name</label>
                        <input type="text" id="editFirstName" placeholder="First name" />
                    </div>
                    <div class="edit-field-group">
                        <label for="editLastName">Last Name</label>
                        <input type="text" id="editLastName" placeholder="Last name" />
                    </div>
                    <div class="edit-field-group">
                        <label for="editEmail">Email</label>
                        <input type="email" id="editEmail" placeholder="email@example.com" />
                    </div>
                    <div class="edit-field-group">
                        <label for="editRole">Role</label>
                        <select id="editRole">
                            <option value="student">Student</option>
                            <option value="instructor">Instructor</option>
                            <option value="admin">Admin</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="um-modal-footer">
                <button class="btn btn-ghost" onclick="closeEditModal()">Cancel</button>
                <button class="btn btn-edit" onclick="saveEdit()">
                    <i class="fas fa-floppy-disk"></i> Save Changes
                </button>
            </div>
        </div>
    </div>

    <script src="/js/admin-users.js"></script>
</body>
</html>

<aside class="sidebar">
  <div class="sidebar-logo">
    <div class="logo-icon">📚</div>
    <div class="logo-text">Loom<span>Hub</span></div>
  </div>

  <div class="sidebar-section">
    <div class="sidebar-label">Overview</div>
    <a class="nav-item <%= (typeof activePage !== 'undefined' && activePage === 'dashboard') ? 'active' : '' %>" href="/dashboard">
      <span class="nav-icon">🏠</span> Dashboard
    </a>
    <a class="nav-item <%= (typeof activePage !== 'undefined' && activePage === 'profile') ? 'active' : '' %>" href="/profile" target="_self">
      <span class="nav-icon">👤</span> My Profile
    </a>
  </div>
  
  <div class="sidebar-section">
    <div class="sidebar-label">Resources</div>
    <a class="nav-item <%= (typeof activePage !== 'undefined' && activePage === 'notes-files') ? 'active' : '' %>" href="/instructor-notes-files">
        <span class="nav-icon">📂</span> Notes & Files
    </a>
    <a class="nav-item <%= (typeof activePage !== 'undefined' && activePage === 'shared-materials') ? 'active' : '' %>" href="/instructor-shared-materials">
    <span class="nav-icon">🔗</span> Shared Materials
    </a>
  </div>

  <div class="sidebar-section">
    <div class="sidebar-label">Collaborate</div>
    <a class="nav-item <%= (typeof activePage !== 'undefined' && activePage === 'Q&A') ? 'active' : '' %>" href="/Q&A">
      <span class="nav-icon">💬</span> Q&amp;A Forum
    </a>
  </div>

  <div class="sidebar-profile" style="cursor: pointer;" onclick="window.location.href='/profile'">
  <div class="avatar">
    <img src="<%= user.profile_picture %>" alt="Profile" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;">
  </div>
  <div class="profile-info">
    <div class="name"><%= user && user.name ? user.name : 'Instructor Account' %></div>
    <div class="role">
      <%= user && user.university ? user.university : 'MIU' %> · Professor
    </div>
  </div>
</div>
</aside>
<div class="sidebar">
  <div class="sidebar-logo">
    <div class="logo-icon">LH</div>
    <div class="logo-text">LoomHub <span>Admin</span></div>
  </div>

  <div class="sidebar-section">
    <div class="sidebar-label">Platform</div>
    
    <a class="nav-item <%= locals.activePage === 'dashboard' ? 'active' : '' %>" href="/admin/dashboard">
    <span class="nav-icon">📊</span> Dashboard
</a>

<a class="nav-item <%= locals.activePage === 'users' ? 'active' : '' %>" href="/admin/users">
    <span class="nav-icon">👥</span> Manage Users
</a>

<a class="nav-item <%= locals.activePage === 'analytics' ? 'active' : '' %>" href="/admin/analytics">
    <span class="nav-icon">📈</span> Analytics
</a>
  </div>

  <div class="sidebar-profile" style="cursor: pointer;" onclick="window.location.href='/profile'">
    <div class="avatar lg purple">
      <% if (locals.user && user.profile_picture) { %>
        <img src="<%= user.profile_picture %>" alt="Profile" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;">
      <% } else { %>
        A
      <% } %>
    </div>
    <div class="profile-info">
      <div class="name"><%= locals.user && user.firstName ? user.firstName : 'System Admin' %></div>
      <div class="role">Full Access</div>
    </div>
  </div>
</div>
<!-- Inside views/partials/topbar.ejs -->
<header class="topbar">
  <div>
    <div class="topbar-title">🏠 Dashboard</div>
    <div class="topbar-subtitle" id="current-date"></div>
  </div>
  <div class="topbar-right">
    <div class="icon-btn">🔔 <div class="notif-dot"></div></div>
    <!-- 🌟 Updated Avatar Container to display the dynamic profile picture -->
    <div class="avatar sm" style="cursor: pointer; overflow: hidden; display: flex; align-items: center; justify-content: center;" onclick="window.location.href='/profile'">
      <img src="<%= user.profile_picture %>" alt="Profile" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;">
    </div>
  </div>
</header>
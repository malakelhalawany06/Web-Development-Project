<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>LoomHub — Analytics</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/project web.css">
    <link rel="stylesheet" href="/css/analytics.css">
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body>
    <% 
        const currentStats = locals.stats || { totalUsers: 0, totalTrend: 0, activeUsers: 0, activeTrend: 0, newUsers: 0, newTrend: 0 }; 
        const safeUser = locals.user || { firstName: 'A', lastName: 'D' };
        const safeChartData = locals.chartData || { labels: [], data: [] };
    %>

    <div class="layout">
  
        <%- include('partials/sidebar-admin', { activePage: 'analytics' }) %>

        <div class="main">
            <div class="topbar-right">
                <div class="icon-btn">🔔 <div class="notif-dot"></div></div>
                <div class="avatar sm">
                    <% if (safeUser && safeUser.firstName && safeUser.lastName) { %>
                        <%= safeUser.firstName.charAt(0) %><%= safeUser.lastName.charAt(0) %>
                    <% } else { %>
                        AD
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <main class="main-content" style="flex: 1; padding: 20px 40px; overflow-y: auto;">
        
        <div class="analytics-grid">
            <div class="stat-card">
                <div class="stat-icon" style="background: rgba(59, 130, 246, 0.1); color: #3b82f6;">
                    <i class="fas fa-users"></i>
                </div>
                <div class="stat-details">
                    <h3>Total Users</h3>
                    <div class="stat-number"><%= currentStats.totalUsers %></div>
                    <div class="stat-trend <%= currentStats.totalTrend >= 0 ? 'positive' : 'negative' %>">
                        <i class="fas fa-arrow-<%= currentStats.totalTrend >= 0 ? 'up' : 'down' %>"></i> 
                        <%= Math.abs(currentStats.totalTrend) %>% this month
                    </div>
                </div>
            </div>
            
            <div class="stat-card">
                <div class="stat-icon" style="background: rgba(34, 197, 94, 0.1); color: #22c55e;">
                    <i class="fas fa-user-check"></i>
                </div>
                <div class="stat-details">
                    <h3>Active Users</h3>
                    <div class="stat-number"><%= currentStats.activeUsers %></div>
                    <div class="stat-trend <%= currentStats.activeTrend >= 0 ? 'positive' : 'negative' %>">
                        <i class="fas fa-arrow-<%= currentStats.activeTrend >= 0 ? 'up' : 'down' %>"></i> 
                        <%= Math.abs(currentStats.activeTrend) %>% this week
                    </div>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon" style="background: rgba(168, 85, 247, 0.1); color: #a855f7;">
                    <i class="fas fa-user-plus"></i>
                </div>
                <div class="stat-details">
                    <h3>New Users</h3>
                    <div class="stat-number"><%= currentStats.newUsers %></div>
                    <div class="stat-trend <%= currentStats.newTrend >= 0 ? 'positive' : 'negative' %>">
                        <i class="fas fa-arrow-<%= currentStats.newTrend >= 0 ? 'up' : 'down' %>"></i> 
                        <%= Math.abs(currentStats.newTrend) %>% since yesterday
                    </div>
                </div>
            </div>
        </div>

        <div class="panel chart-panel">
            <div class="panel-header" style="display: flex; justify-content: space-between; align-items: center;">
                <div class="panel-title">User Growth</div>
                <div class="chart-toggle">
                    <button class="toggle-btn active" onclick="updateChart('daily')">Daily</button>
                    <button class="toggle-btn" onclick="updateChart('weekly')">Weekly</button>
                </div>
            </div>
            <div class="canvas-container" style="position: relative; height: 350px; width: 100%;">
                <canvas id="growthChart"></canvas>
            </div>
        </div>

    </main>

    <script>
        // Safely injected tracking data with array layout fallbacks
        const serverChartData = <%- JSON.stringify(safeChartData) %>;
    </script>
    <script src="/js/analytics.js"></script>
</body>
</html>
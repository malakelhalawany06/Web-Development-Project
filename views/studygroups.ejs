<!DOCTYPE html>
<html>
    <head>
        <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
        <link rel="stylesheet" href="/css/project web.css">
        <link rel="stylesheet" href="/css/studygroups.css">
    </head>
    <body>
        <div class="layout">

            <!-- ===== SIDEBAR ===== -->
            <aside class="sidebar">
                <div class="sidebar-logo">
                    <div class="logo-icon">📚</div>
                    <div class="logo-text">Loom<span>Hub</span></div>
                </div>

                <div class="sidebar-section">
                    <div class="sidebar-label">Overview</div>
                    <a class="nav-item" href="/dashboard">
                        <span class="nav-icon">🏠</span> Dashboard
                    </a>
                    <a class="nav-item" href="/profile">
                        <span class="nav-icon">👤</span> My Profile
                    </a>
                </div>

                <div class="sidebar-section">
                    <div class="sidebar-label">Academic</div>
                    <a class="nav-item" href="/gpa-calculator">
                        <span class="nav-icon">🎓</span> GPA Calculator
                    </a>
                    <a class="nav-item" href="/reminders">
                        <span class="nav-icon">⏰</span> Tasks & Reminders
                        <span class="nav-badge warn">2</span>
                    </a>
                </div>

                <div class="sidebar-section">
                    <div class="sidebar-label">Resources</div>
                    <a class="nav-item" href="/notes-files">
                        <span class="nav-icon">📂</span> Notes & Files
                        <span class="nav-badge" id="notesFilesBadge">0</span>
                    </a>
                    <a class="nav-item" href="/shared-materials">
                        <span class="nav-icon">🔗</span> Shared Materials
                    </a>
                </div>

                <div class="sidebar-section">
                    <div class="sidebar-label">Collaborate</div>
                    <a class="nav-item active" href="/studygroups">
                        <span class="nav-icon">👥</span> Study Groups
                        <span class="nav-badge green" id="studyGroupsBadge">0</span>
                    </a>
                    <a class="nav-item" href="/project-manager">
                        <span class="nav-icon">🗂</span> Project Manager
                    </a>
                    <a class="nav-item" href="/qa">
                        <span class="nav-icon">💬</span> Q&amp;A Forum
                    </a>
                </div>

                <div class="sidebar-section">
                    <div class="sidebar-label">Admin Panel</div>
                    <a class="nav-item" href="/user-management">
                        <span class="nav-icon">🛡</span> User Management
                    </a>
                    <a class="nav-item" href="/analytics">
                        <span class="nav-icon">📊</span> Analytics
                    </a>
                </div>

                <div class="sidebar-profile" style="cursor: pointer;" onclick="window.location.href='/profile'">
                    <div class="avatar"><%= user ? user.fullName.charAt(0) : 'G' %></div>
                    <div class="profile-info">
                        <div class="name"><%= user ? user.fullName : 'Guest' %></div>
                        <div class="role"><%= user ? (user.major || 'Student') : 'Please login' %> · Yr <%= user ? (user.academicYear || '?') : '?' %></div>
                    </div>
                </div>
            </aside>

            <div class="main">
                <!-- Topbar -->
                <header class="topbar">
                    <div>
                        <div class="topbar-title">👥 Study Groups</div>
                        <div class="topbar-subtitle">Find and join study groups</div>
                    </div>
                    <div class="topbar-right">
                        <div class="topbar-search">
                            <span>🔍</span>
                            <input type="text" id="topbar-search-input" placeholder="Search groups...">
                        </div>
                        <div class="icon-btn">🔔 <div class="notif-dot"></div></div>
                        <div class="avatar sm"><%= user ? user.fullName.charAt(0) : 'G' %></div>
                    </div>
                </header>

                <div class="content">
                    <div class="card">
                        <div class="card-header">
                            <h1 class="card-title">👥 My Study Groups</h1>
                            <button class="btn btn-primary" onclick="openCreateGroupModal()">+ Create New Group</button>
                        </div>
                        <div class="search-bar">
                            <span>🔍</span>
                            <input type="text" id="groupSearchInput" placeholder="Search groups...">
                        </div>
                        <div class="filter-section">
                        </div>
                        <div class="groups-grid" id="groupsGrid">
                            <!-- Groups will be loaded dynamically via JavaScript -->
                        </div>
                    </div>
                </div>
            </div> <!-- CLOSE .main -->

        </div> <!-- CLOSE .layout -->

        <!-- MODAL - OUTSIDE .layout -->
        <div id="createGroupModal" class="modal">
            <div class="modal-content">
                <h2>Create New Study Group</h2>
                <form id="createGroupForm">
                    <div class="form-group">
                        <label>Group Name *</label>
                        <input type="text" id="groupName" placeholder="Enter group name" required>
                    </div>
                    <div class="form-group">
                        <label>Course/Subject</label>
                        <input type="text" id="groupCourse" placeholder="Enter course name">
                    </div>
                    <div class="form-group">
                        <label>Category</label>
                        <select id="groupCategory">
                            <option value="cs">Computer Science</option>
                            <option value="math">Mathematics</option>
                            <option value="engineering">Engineering</option>
                            <option value="business">Business</option>
                            <option value="arts">Arts</option>
                            <option value="law">Law</option>
                            <option value="science">Science</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Description *</label>
                        <textarea id="groupDescription" rows="3" placeholder="What will this group focus on? Meeting schedule"></textarea>
                    </div>
                    <div class="modal-actions">
                        <button type="button" class="btn btn-outline" onclick="closeCreateGroupModal()">Cancel</button>
                        <button type="submit" class="btn btn-primary">Create Group</button>
                    </div>
                </form>
            </div>
        </div>

        <script src="/js/users.js"></script>
        <script src="/js/studygroups.js"></script>
        <script src="/js/personalInfo.js"></script>
        
        <script>
            // Pass user data to JavaScript
            window.currentUser = {
                id: '<%= user ? user._id : "" %>',
                username: '<%= user ? user.username : "" %>',
                fullName: '<%= user ? user.fullName : "" %>',
                major: '<%= user ? user.major : "" %>',
                academicYear: '<%= user ? user.academicYear : "" %>'
            };
        </script>
    </body>
</html>
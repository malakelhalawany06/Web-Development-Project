<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GPA Calculator</title>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />   
    <link rel="stylesheet" href="/css/project web.css">
    <link rel="stylesheet" href="/css/Gpa-calculator.css">
</head>
<body>

<div class="layout">

  <aside class="sidebar">
    <div class="sidebar-logo">
      <div class="logo-icon">📚</div>
      <div class="logo-text">Loom<span>Hub</span></div>
    </div>

    <div class="sidebar-section">
      <div class="sidebar-label">Overview</div>
      <a class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'active' : '' %>" href="/dashboard">
        <span class="nav-icon">🏠</span> Dashboard
      </a>
      <a class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'profile' ? 'active' : '' %>" href="/profile">
        <span class="nav-icon">👤</span> My Profile
      </a>
    </div>

    <div class="sidebar-section">
      <div class="sidebar-label">Academic</div>
      <a class="nav-item active" href="/gpa-calculator">
        <span class="nav-icon">🎓</span> GPA Calculator
      </a>
      
      <a class="nav-item" href="/reminders">
        <span class="nav-icon">⏰</span> Tasks & Reminders
        <span class="nav-badge warn">2</span>
      </a>
    </div>

    <div class="sidebar-section">
      <div class="sidebar-label">Resources</div>
      <a class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'notes-files' ? 'active' : '' %>" href="/notes-files">
        <span class="nav-icon">📂</span> Notes & Files
        <span class="nav-badge" id="notesFilesBadge">0</span>
      </a>
      <a class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'shared-materials' ? 'active' : '' %>" href="/shared-materials">
        <span class="nav-icon">🔗</span> Shared Materials
      </a>
    </div>

    <div class="sidebar-section">
      <div class="sidebar-label">Collaborate</div>
      <a class="nav-item" href="/studygroups">
        <span class="nav-icon">👥</span> Study Groups
        <span class="nav-badge green">3</span>
      </a>
      
      <% if (typeof userRole !== 'undefined' && userRole === 'students') { %>
      <a class="nav-item" href="/project-manager">
        <span class="nav-icon">🗂</span> Project Manager
      </a>
      <% } %>
      
      <a class="nav-item" href="/qa-forum">
        <span class="nav-icon">💬</span> Q&amp;A Forum
      </a>
    </div>

    <% if (typeof userRole !== 'undefined' && userRole === 'admins') { %>
    <div class="sidebar-section">
      <div class="sidebar-label">Admin Panel</div>
      <a class="nav-item" href="/user-management">
        <span class="nav-icon">🛡</span> User Management
      </a>
      <a class="nav-item" href="/analytics">
        <span class="nav-icon">📊</span> Analytics
      </a>
    </div>
    <% } %>

    <div class="sidebar-profile" style="cursor: pointer;" onclick="window.location.href='/profile'">
      <div class="avatar">
        <%= user && user.name ? user.name.split(' ').map(n => n[0]).join('').toUpperCase() : 'U' %>
      </div>
      <div class="profile-info">
        <div class="name"><%= user ? user.name : 'User' %></div>
        <div class="role">
            <%= user && user.major ? user.major : 'Student' %> 
            <%= user && (user.academic_year || user.year) ? '· Yr ' + (user.academic_year || user.year) : '' %>
        </div>
      </div>
    </div>
  </aside>

  <div class="main">

    <header class="topbar">
        <div>
            <div class="topbar-title">🎓 GPA Calculator</div>
            <div class="topbar-subtitle">University GPA System</div>
        </div>
        <div class="topbar-right">
            <div class="icon-btn">🔔 <div class="notif-dot"></div></div>
            <div class="avatar sm">
                <%= user && user.name ? user.name.split(' ').map(n => n[0]).join('').toUpperCase() : 'U' %>
            </div>
        </div>
    </header>

    <div class="content">

        <div class="card">
            <div class="card-header">
                <span class="card-title">➕ Add Course</span>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="courseName">Course Name</label>
                    <input type="text" id="courseName" placeholder="Enter course name" class="form-input">
                </div>
                
                <div class="form-group">
                    <label for="credits">Credit Hours</label>
                    <input type="number" id="credits" placeholder="E.g. 3" class="form-input">
                </div>

                <div class="form-group">
                    <label for="grade">Grade</label>
                    <select id="grade" class="form-input">
                        <option value="">Select Grade</option>
                        <option value="4.0">A</option>
                        <option value="3.7">A-</option>
                        <option value="3.3">B+</option>
                        <option value="3.0">B</option>
                        <option value="2.7">B-</option>
                        <option value="2.3">C+</option>
                        <option value="2.0">C</option>
                        <option value="1.0">D</option>
                        <option value="0.0">F</option>
                    </select>
                </div>
            </div>

            <button class="btn btn-primary" style="margin-top: 1.25rem;" onclick="addCourse()">+ Add Course</button>
        </div>

        <div class="card">
            <div class="card-header">
                <span class="card-title">📊 Courses</span>
            </div>

            <table class="gpa-table">
                <thead>
                    <tr>
                        <th>Course</th>
                        <th>Credits</th>
                        <th>Grade</th>
                        <th>Points</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="courseTable"></tbody>
            </table>

            <div class="gpa-result">
                <div>
                    <div style="font-size:11px;color:var(--text3);">Database GPA</div>
                    <div class="gpa-val" id="gpaValue">
                        <%= (user && typeof user.gpa !== 'undefined') ? Number(user.gpa).toFixed(2) : '0.00' %>
                    </div>
                </div>

                <div class="gpa-bar-wrap">
                    <% 
                        let dbGpaPercentage = 0;
                        if (user && typeof user.gpa !== 'undefined') {
                            dbGpaPercentage = (Number(user.gpa) / 4.0) * 100;
                        }
                    %>
                    <div class="gpa-bar-fill" id="gpaBar" style="width: <%= dbGpaPercentage %>%"></div>
                </div>

                <div>
                    <div style="font-size:11px;color:var(--text3);">Scale</div>
                    <div>4.0</div>
                </div>
            </div>

        </div>

    </div>
  </div>
</div>

<script>
let courses = [];

document.addEventListener("DOMContentLoaded", () => {
    console.log("Embedded GPA Calculator Active.");
    updateGPADisplay();
});

function addCourse() {
    const nameInput = document.getElementById("courseName");
    const creditsInput = document.getElementById("credits");
    const gradeSelect = document.getElementById("grade");

    const name = nameInput.value.trim();
    const credits = parseInt(creditsInput.value);
    const gradeValue = parseFloat(gradeSelect.value);
    const gradeText = gradeSelect.options[gradeSelect.selectedIndex].text;

    if (!name || isNaN(credits) || isNaN(gradeValue)) {
        alert("Please fill out all course details correctly.");
        return;
    }

    const points = (credits * gradeValue).toFixed(2);
    const course = { id: Date.now(), name, credits, gradeValue, gradeText, points };
    courses.push(course);

    nameInput.value = "";
    creditsInput.value = "";
    gradeSelect.value = "";

    renderTable();
    calculateLiveGPA();
}

function removeCourse(id) {
    courses = courses.filter(c => c.id !== id);
    renderTable();
    calculateLiveGPA();
}

function renderTable() {
    const tbody = document.getElementById("courseTable");
    tbody.innerHTML = "";

    courses.forEach(c => {
        const row = document.createElement("tr");
        row.innerHTML = `
            <td><strong>${c.name}</strong></td>
            <td>${c.credits} hrs</td>
            <td><span class="badge">${c.gradeText}</span></td>
            <td>${c.points}</td>
            <td><button class="btn" style="background:#ff4a4a;padding:4px 8px;font-size:11px;" onclick="removeCourse(${c.id})">🗑 Delete</button></td>
        `;
        tbody.appendChild(row);
    });
}

function calculateLiveGPA() {
    if (courses.length === 0) {
        updateGPADisplay();
        return;
    }

    let totalCredits = 0;
    let totalPoints = 0;

    courses.forEach(c => {
        totalCredits += c.credits;
        totalPoints += parseFloat(c.points);
    });

    const liveGPA = (totalPoints / totalCredits).toFixed(2);
    
    // Update live layout interface view 
    document.getElementById("gpaValue").innerText = liveGPA;
    const percentage = (liveGPA / 4.0) * 100;
    document.getElementById("gpaBar").style.width = `${Math.min(percentage, 100)}%`;
}

function updateGPADisplay() {
    const gpaValBox = document.getElementById("gpaValue");
    const currentVal = parseFloat(gpaValBox.innerText) || 0.00;
    const percentage = (currentVal / 4.0) * 100;
    document.getElementById("gpaBar").style.width = `${Math.min(percentage, 100)}%`;
}
</script>

</body>
</html>
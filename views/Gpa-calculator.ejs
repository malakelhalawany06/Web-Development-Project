<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GPA Calculator</title>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />   
    <link rel="stylesheet" href="/css/project web.css">
    <link rel="stylesheet" href="/css/Gpa-calculator.css">
</head>
<body>

<div id="gpaCalculatorApp" data-user-id="<%= user ? (user._id || 'guest') : 'guest' %>" class="layout">
  
  <%- include('partials/sidebar-student') %>

  <div class="main">

    <header class="topbar">
        <div>
            <div class="topbar-title">🎓 GPA Calculator</div>
            <div class="topbar-subtitle">University GPA System</div>
        </div>
        <div class="topbar-right">
            <div class="icon-btn">🔔 <div class="notif-dot"></div></div>
            <div class="avatar sm">
                <%= user && user.name ? user.name.split(' ').map(n => n[0]).join('').toUpperCase() : 'U' %>
            </div>
        </div>
    </header>

    <div class="content">

        <div class="card">
            <div class="card-header">
                <span class="card-title">➕ Add Course</span>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="courseName">Course Name</label>
                    <input type="text" id="courseName" placeholder="Enter course name" class="form-input">
                </div>
                
                <div class="form-group">
                    <label for="credits">Credit Hours</label>
                    <input type="number" id="credits" placeholder="E.g. 3" class="form-input">
                </div>

                <div class="form-group">
                    <label for="grade">Grade</label>
                    <select id="grade" class="form-input">
                        <option value="">Select Grade</option>
                        <option value="4.0">A</option>
                        <option value="3.7">A-</option>
                        <option value="3.3">B+</option>
                        <option value="3.0">B</option>
                        <option value="2.7">B-</option>
                        <option value="2.3">C+</option>
                        <option value="2.0">C</option>
                        <option value="1.0">D</option>
                        <option value="0.0">F</option>
                    </select>
                </div>
            </div>

            <button class="btn btn-primary" style="margin-top: 1.25rem;" onclick="addCourse()">+ Add Course</button>
        </div>

        <div class="card">
            <div class="card-header">
                <span class="card-title">📊 Courses</span>
            </div>

            <table class="gpa-table">
                <thead>
                    <tr>
                        <th>Course</th>
                        <th>Credits</th>
                        <th>Grade</th>
                        <th>Points</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="courseTable">
                    <% if (user && user.courses && user.courses.length > 0) { %>
                        <% user.courses.forEach(function(c) { %>
                            <tr>
                                <td><strong><%= c.name %></strong></td>
                                <td><%= c.credits %> hrs</td>
                                <td><span class="badge"><%= c.gradeText %></span></td>
                                <td><%= c.points %></td>
                                <td>
                                    <button class="btn" style="background:#ff4a4a;padding:4px 8px;font-size:11px;color:white;border:none;border-radius:4px;cursor:pointer;" onclick="removeCourse(<%= c.id %>)">🗑 Delete</button>
                                </td>
                            </tr>
                        <% }); %>
                    <% } %>
                </tbody>
            </table>

            <div class="gpa-result">
                <div>
                    <div style="font-size:11px;color:var(--text3);">Database GPA</div>
                    <div class="gpa-val" id="gpaValue">
                        <% 
                            let displayGpa = 0.00;
                            if (user) {
                                if (typeof user.gpa !== 'undefined') displayGpa = user.gpa;
                                else if (typeof user.GPA !== 'undefined') displayGpa = user.GPA;
                            }
                        %><%= Number(displayGpa).toFixed(2) %>
                    </div>
                </div>

                <div class="gpa-bar-wrap">
                    <div class="gpa-bar-fill" id="gpaBar" style="width: 0%"></div>
                </div>

                <div>
                    <div style="font-size:11px;color:var(--text3);">Scale</div>
                    <div>4.0</div>
                </div>
            </div>

        </div>

    </div>
  </div>
</div>

<script src="/js/gpa-calculator.js"></script>

</body>
</html>
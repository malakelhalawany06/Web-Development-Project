<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>LoomHub — Student Platform</title>
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/project web.css">
  <script src="/js/users.js"></script>
  <script src="/js/project web.js"></script>
  <script src="/js/project web trial 1.js"></script>
  <script src="/js/dashboard.js"></script>
  <script src="/js/recent-notes-groups.js"></script>
</head>
<body class="layout">

  <%- include('partials/sidebar-student') %>

  <div class="main" id="dashboardAppWrapper" data-user-id="<%= typeof user !== 'undefined' && user ? (user._id || 'guest') : 'guest' %>">

    <%- include('partials/topbar') %>
    
    <div class="content">

      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-icon">🎓</div>
          <div class="stat-val" id="topDashboardGpaCard">
            <% 
                let baseSavedGpa = 0.00;
                if (typeof user !== 'undefined' && user) {
                    if (typeof user.gpa !== 'undefined') baseSavedGpa = user.gpa;
                    else if (typeof user.GPA !== 'undefined') baseSavedGpa = user.GPA;
                }
            %><%= Number(baseSavedGpa).toFixed(2) %>
          </div>
          <div class="stat-label">Current GPA</div>
          <div class="stat-change" id="gpaRealtimeStatusText">Live Dashboard Matrix</div>
        </div>
        
        <div class="stat-card">
          <div class="stat-icon">✅</div>
          <div class="stat-val" id="completedTasksCount">0</div>
          <div class="stat-label">Tasks completed</div>
          <div class="stat-change" id="completedTodayChange">↑ 0 today</div>
        </div>
        
        <div class="stat-card">
          <div class="stat-icon">⚠️</div>
          <div class="stat-val" id="pendingTasksCount">0</div>
          <div class="stat-label">Pending reminders</div>
          <div class="stat-change warn" id="urgentCount">0 high priority</div>
        </div>
        
        <div class="stat-card">
          <div class="stat-icon">👥</div>
          <div class="stat-val">3</div>
          <div class="stat-label">Active study groups</div>
          <div class="stat-change">1 new invite</div>
        </div>
      </div>

      <div class="main-grid">

        <div class="card">
          <div class="card-header">
            <span class="card-title">🎓 GPA Calculator</span>
            <button class="btn btn-ghost" onclick="toggleDashGpaForm()" style="padding:4px 10px;font-size:12px;">+ Add Course</button>
          </div>

          <div id="dash-gpa-form" style="display: none; gap: 8px; margin-bottom: 15px; align-items: center; flex-wrap: wrap;">
            <input type="text" id="dashCourseName" placeholder="Course Name" style="flex: 1; background: var(--surface); border: 1px solid var(--border); color: var(--text); padding: 6px 10px; border-radius: var(--radius-sm); outline: none; font-size: 12px; font-family: var(--font);">
            <input type="number" id="dashCredits" placeholder="Cr" style="width: 50px; background: var(--surface); border: 1px solid var(--border); color: var(--text); padding: 6px; border-radius: var(--radius-sm); outline: none; font-size: 12px; font-family: var(--font);">
            <select id="dashGrade" style="width: 85px; background: var(--surface); border: 1px solid var(--border); color: var(--text); padding: 6px; border-radius: var(--radius-sm); outline: none; font-size: 12px; font-family: var(--font);">
              <option value="">Grade</option>
              <option value="4.0">A</option>
              <option value="3.7">A-</option>
              <option value="3.3">B+</option>
              <option value="3.0">B</option>
              <option value="2.7">B-</option>
              <option value="2.3">C+</option>
              <option value="2.0">C</option>
              <option value="1.0">D</option>
              <option value="0.0">F</option>
            </select>
            <button class="btn btn-primary" onclick="addDashCourse()" style="padding: 6px 12px; font-size: 12px;">Add</button>
          </div>

          <table class="gpa-table">
            <thead>
              <tr>
                <th>Course</th>
                <th>Credits</th>
                <th>Grade</th>
                <th>Points</th>
                <th style="text-align: center; width: 40px;">Wipe</th>
              </tr>
            </thead>
            <tbody id="dashCourseTable">
               </tbody>
          </table>

          <div class="gpa-result">
            <div>
              <div style="font-size:11px;color:var(--text3);margin-bottom:2px;">Semester GPA</div>
              <div class="gpa-val" id="dashGpaValue">0.00</div>
            </div>
            <div class="gpa-bar-wrap">
              <div class="gpa-bar-fill" id="dashGpaBar" style="width:0%"></div>
            </div>
            <div style="text-align:right;">
              <div style="font-size:11px;color:var(--text3);">System</div>
              <div style="font-family:var(--mono);font-size:13px;color:var(--text2);">4.0 Scale</div>
            </div>
          </div>
        </div>

        <div class="card">
          <div class="card-header">
            <span class="card-title">✅ Tasks & Reminders</span>
            <div class="tabs">
              <div class="tab active" data-tab="tasks">To-Do</div>
            </div>
          </div>
          <div id="tasksListContainer"></div>
          <div style="margin-top:1rem;">
            <button class="btn btn-primary" id="addTaskBtn" style="width:100%;justify-content:center;">+ Add New Task</button>
          </div>
        </div>

        <div style="display:flex;flex-direction:column;gap:1.25rem;">
          <div class="card">
            <div class="card-header">
              <span class="card-title">⏰ Upcoming Deadlines</span>
              <span class="card-action" style="cursor: pointer;" onclick="window.location.href='/tasks-reminders'">View all</span>
            </div>
            <div id="deadlinesList" class="deadline-list"></div>
          </div>

          <div class="card">
            <div class="card-header">
              <span class="card-title">📂 Recent Notes</span>
              <span class="card-action" style="cursor: pointer;" onclick="window.location.href='/notes-files'">Browse</span>
            </div>
            <div id="recentNotesContainer" class="notes-grid">
               </div>
          </div>
        </div>

        <div class="card">
          <div class="card-header">
            <span class="card-title">👥 Study Groups</span>
            <button class="btn btn-ghost" style="padding:4px 10px;font-size:12px;" onclick="window.location.href='/studygroups'">View All</button>
          </div>
          <div id="recentGroupsContainer">
            <div style="text-align: center; padding: 2rem; color: var(--text3);">Loading your study groups...</div>
          </div>
        </div>

        <div class="card">
          <div class="card-header">
            <span class="card-title">🗂 Projects</span>
            <button class="btn btn-ghost" style="padding:4px 10px;font-size:12px;" onclick="window.location.href='/project-manager'">+ New Project</button>
          </div>

          <div class="project-item" style="cursor: pointer;" onclick="window.location.href='/project-manager'">
            <div class="project-top">
              <span class="project-name">Library Management System</span>
              <span class="project-pct">72%</span>
            </div>
            <div class="prog-bar"><div class="prog-fill fill-accent" style="width:72%"></div></div>
            <div class="project-meta">
              <div class="member-stack">
                <div class="avatar sm">AK</div>
                <div class="avatar sm green">NM</div>
                <div class="avatar sm warn">SO</div>
              </div>
              <span style="font-size:11px;color:var(--text3);">Due Apr 18</span>
            </div>
          </div>

          <div class="project-item" style="cursor: pointer;" onclick="window.location.href='/project-manager'">
            <div class="project-top">
              <span class="project-name">E-Commerce App (Networks)</span>
              <span class="project-pct">40%</span>
            </div>
            <div class="prog-bar"><div class="prog-fill fill-warn" style="width:40%"></div></div>
            <div class="project-meta">
              <div class="member-stack">
                <div class="avatar sm">AK</div>
                <div class="avatar sm purple">YR</div>
              </div>
              <span style="font-size:11px;color:var(--danger);">Due Apr 22</span>
            </div>
          </div>

          <div class="project-item" style="cursor: pointer;" onclick="window.location.href='/project-manager'">
            <div class="project-top">
              <span class="project-name">Research Paper — AI Ethics</span>
              <span class="project-pct">91%</span>
            </div>
            <div class="prog-bar"><div class="prog-fill fill-green" style="width:91%"></div></div>
            <div class="project-meta">
              <div class="member-stack">
                <div class="avatar sm">AK</div>
                <div class="avatar sm green">NM</div>
                <div class="avatar sm warn">SO</div>
                <div class="avatar sm purple">YR</div>
              </div>
              <span style="font-size:11px;color:var(--accent3);">Due Apr 30</span>
            </div>
          </div>
        </div>

        <div class="card">
          <div class="card-header">
            <span class="card-title">💬 Q&amp;A Forum</span>
            <button class="btn btn-primary" onclick="toggleDashQAForm()" style="padding:4px 10px;font-size:12px;">Ask Question</button>
          </div>
          <div id="dash-qa-form" style="display: none; flex-direction: column; gap: 8px; margin-bottom: 15px;">
            <input type="text" id="dashQATitle" placeholder="What's your question?" style="background: var(--surface); border: 1px solid var(--border); color: var(--text); padding: 8px 10px; border-radius: var(--radius-sm); outline: none; font-size: 13px; font-family: var(--font); width: 100%;">
            <div style="display: flex; gap: 8px;">
              <select id="dashQATag" style="flex: 1; background: var(--surface); border: 1px solid var(--border); color: var(--text); padding: 6px; border-radius: var(--radius-sm); outline: none; font-size: 12px; font-family: var(--font);">
                <option value="Data Structures">Data Structures</option>
                <option value="Database Systems">Database Systems</option>
                <option value="Networks">Networks</option>
                <option value="General">General</option>
              </select>
              <button class="btn btn-primary" onclick="submitDashQuestion()" style="padding: 6px 12px; font-size: 12px;">Post</button>
            </div>
          </div>
          <div id="dashQAContainer"></div>
        </div>

      </div></div></div></body>
</html>
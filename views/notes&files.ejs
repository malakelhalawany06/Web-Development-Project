<!DOCTYPE html>
<html>
<head>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/project web.css">
    <link rel="stylesheet" href="/css/notes&files.css">
</head>
<body>
    <div class="layout">

        <!-- ===== SIDEBAR ===== -->
        <aside class="sidebar">
            <div class="sidebar-logo">
                <div class="logo-icon">📚</div>
                <div class="logo-text">Loom<span>Hub</span></div>
            </div>

            <div class="sidebar-section">
                <div class="sidebar-label">Overview</div>
                <a class="nav-item" href="/dashboard">
                    <span class="nav-icon">🏠</span> Dashboard
                </a>
                <a class="nav-item" href="/profile">
                    <span class="nav-icon">👤</span> My Profile
                </a>
            </div>

            <div class="sidebar-section">
                <div class="sidebar-label">Academic</div>
                <a class="nav-item" href="/gpa-calculator">
                    <span class="nav-icon">🎓</span> GPA Calculator
                </a>
                <a class="nav-item" href="/reminders">
                    <span class="nav-icon">⏰</span> Tasks & Reminders
                    <span class="nav-badge warn">2</span>
                </a>
            </div>

            <div class="sidebar-section">
                <div class="sidebar-label">Resources</div>
                <a class="nav-item active" href="/notes-files">
                    <span class="nav-icon">📂</span> Notes & Files
                    <span class="nav-badge" id="notesFilesBadge">0</span>
                </a>
                <a class="nav-item" href="/shared-materials">
                    <span class="nav-icon">🔗</span> Shared Materials
                </a>
            </div>

            <div class="sidebar-section">
                <div class="sidebar-label">Collaborate</div>
                <a class="nav-item" href="/studygroups">
                    <span class="nav-icon">👥</span> Study Groups
                    <span class="nav-badge green">0</span>
                </a>
                <a class="nav-item" href="/project-manager">
                    <span class="nav-icon">🗂</span> Project Manager
                </a>
                <a class="nav-item" href="/qa">
                    <span class="nav-icon">💬</span> Q&amp;A Forum
                </a>
            </div>

            <div class="sidebar-section">
                <div class="sidebar-label">Admin Panel</div>
                <a class="nav-item" href="/user-management">
                    <span class="nav-icon">🛡</span> User Management
                </a>
                <a class="nav-item" href="/analytics">
                    <span class="nav-icon">📊</span> Analytics
                </a>
            </div>

            <div class="sidebar-profile">
                <div class="avatar"><%= user ? user.name.charAt(0) : 'G' %></div>
                <div class="profile-info">
                    <div class="name"><%= user ? user.name : 'Guest' %></div>
                    <div class="role"><%= user ? (user.major || 'Student') : 'Please login' %> · Yr <%= user ? (user.academic_year || '?') : '?' %></div>
                </div>
            </div>
        </aside>

        <div class="main">
            <!-- Topbar -->
            <header class="topbar" style="height:64.17px">
                <div>
                    <div class="topbar-title">📂 Notes & Files</div>
                    <div class="topbar-subtitle">Study Materials</div>
                </div>
                <div class="topbar-right">
                    <div class="topbar-search">
                        <span>🔍</span>
                        <input type="text" id="topbar-search-input" placeholder="Search files...">
                    </div>
                    <div class="icon-btn">🔔 <div class="notif-dot"></div></div>
                    <div class="avatar sm"> <%= user && user.name ? user.name[0] : 'G' %> </div>
                </div>
            </header>

            <div class="content">
                <!-- Upload Button Bar -->
                <div class="upload-bar">
                    <button class="btn btn-primary" onclick="window.location.href='/shared-materials'">+ Upload New File</button>
                    <div class="view-toggle">
                        <button class="view-btn active" onclick="setView('grid')">📱 Grid View</button>
                        <button class="view-btn" onclick="setView('list')">📋 List View</button>
                    </div>
                </div>

                <!-- Course Filter Tabs -->
                <div class="filter-section">
                    <!-- Course tabs will be dynamically added by JavaScript -->
                </div>

                <!-- Files Grid View -->
                <div id="gridView" class="files-grid">
                    <!-- Files will be loaded here by JavaScript -->
                </div>

                <!-- List View -->
                <div id="listView" class="files-list" style="display: none;"></div>
            </div>
        </div>
    </div>

    <script src="/js/users.js"></script>
    <script src="/js/notes&files.js"></script>
    <script src="/js/personalInfo.js"></script>
    
    <script>
        // Pass user data to JavaScript
        window.currentUser = {
            id: '<%= user ? user._id : "" %>',
        name: '<%= user ? user.name : "" %>',
        major: '<%= user ? user.major : "" %>',
        academic_year: '<%= user ? user.academic_year : "" %>',
        username: '<%= user ? user.username : "" %>'
        };
    </script>
</body>
</html>
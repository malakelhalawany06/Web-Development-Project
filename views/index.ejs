<!DOCTYPE html>
<html>
<head>
    <title>LoomHub — Login</title>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    
    <link rel="stylesheet" href="/css/logIn.css">
    <link rel="stylesheet" href="/css/project web.css">
</head>
<body>
    <div class="main-logo"> 
        <div class="logo-icon">📚</div>
        <div class="logo-text">Loom<span>Hub</span></div>
    </div>

    <div id="details">
        <% if (error) { %>
            <div class="error" style="color: red; margin-bottom: 1rem;"><%= error %></div>
        <% } %>

        <form action="/login" method="POST" novalidate>
            <label for="email">Email:</label><br>
            <span id="emailError"></span>
            <input type="email" id="email" name="email" placeholder="Enter Email" required autofocus><br>

            <label for="password">Password:</label><br>
            <span id="passError"></span>
            <input type="password" id="password" name="password" placeholder="Enter Password" required><br>

            <button type="submit">Login</button>

            <div style="margin-top: 1rem;">
                <span>Haven't made an account yet? <a href="/signup">sign up</a></span>
            </div>
        </form>
    </div>

    <script src="/js/users.js"></script>
<%#  <script src="/js/logIn.js"></script>  %>
</body>
</html>
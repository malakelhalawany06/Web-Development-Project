<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LoomHub - Shared Materials</title>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/sharedMaterials.css">
    <link rel="stylesheet" href="/css/project web.css">
</head>
<body>
    <div class="layout">
  
        <!-- ===== SIDEBAR ===== -->
        <aside class="sidebar">
            <div class="sidebar-logo">
                <div class="logo-icon">📚</div>
                <div class="logo-text">Loom<span>Hub</span></div>
            </div>

            <div class="sidebar-section">
                <div class="sidebar-label">Overview</div>
                <a class="nav-item" href="/dashboard">
                    <span class="nav-icon">🏠</span> Dashboard
                </a>
                <a class="nav-item" href="/profile">
                    <span class="nav-icon">👤</span> My Profile
                </a>
            </div>

            <div class="sidebar-section">
                <div class="sidebar-label">Academic</div>
                <a class="nav-item" href="/gpa-calculator">
                    <span class="nav-icon">🎓</span> GPA Calculator
                </a>
                <a class="nav-item" href="/reminders">
                    <span class="nav-icon">⏰</span> Tasks & Reminders
                    <span class="nav-badge warn">2</span>
                </a>
            </div>

            <div class="sidebar-section">
                <div class="sidebar-label">Resources</div>
                <a class="nav-item" href="/notes-files">
                    <span class="nav-icon">📂</span> Notes & Files
                    <span class="nav-badge" id="notesFilesBadge">0</span>
                </a>
                <a class="nav-item active" href="/shared-materials">
                    <span class="nav-icon">🔗</span> Share Material
                </a>
            </div>

            <div class="sidebar-section">
                <div class="sidebar-label">Collaborate</div>
                <a class="nav-item" href="/studygroups">
                    <span class="nav-icon">👥</span> Study Groups
                    <span class="nav-badge green">0</span>
                </a>
                <a class="nav-item" href="/project-manager">
                    <span class="nav-icon">🗂</span> Project Manager
                </a>
                <a class="nav-item" href="/qa">
                    <span class="nav-icon">💬</span> Q&amp;A Forum
                </a>
            </div>

            <div class="sidebar-section">
                <div class="sidebar-label">Admin Panel</div>
                <a class="nav-item" href="/user-management">
                    <span class="nav-icon">🛡</span> User Management
                </a>
                <a class="nav-item" href="/analytics">
                    <span class="nav-icon">📊</span> Analytics
                </a>
            </div>

            <div class="sidebar-profile">
                <div class="avatar"><%= user ? user.name?.charAt(0) || 'G' : 'G' %></div>
                <div class="profile-info">
                    <div class="name"><%= user ? user.name : 'Guest' %></div>
                    <div class="role"><%= user ? (user.major || 'Student') : 'Please login' %> · Year <%= user ? user.academic_year : '?' %></div>
                </div>
            </div>
        </aside>

        <main class="main">
            <header class="topbar">
                <div>
                    <div class="topbar-title">📤 Share Material</div>
                    <div class="topbar-subtitle">Share your notes and files with classmates</div>
                </div>
                <div class="topbar-right">
                    
                    <div class="icon-btn">🔔<span class="notif-dot"></span></div>
                    <div class="avatar sm"><%= user ? user.name?.charAt(0) || 'G' : 'G' %></div>
                </div>
            </header>

            <div class="content">
                <!-- Upload Form -->
                <div class="card">
                    <div class="card-header">
                        <div class="card-title">Upload New Material</div>
                    </div>
                    
                    <input type="text" id="upload-title" class="feed-input" placeholder="Material Title (e.g., Chapter 7 Notes)">
                    
                    <!-- Subject Dropdown instead of description -->
                    <select id="upload-subject" class="feed-input" required>
                        <option value="">Select a subject...</option>
                    </select>
                    
                    <div class="upload-footer">
                        <div class="file-input-wrapper">
                            <label for="upload-file" class="btn btn-ghost">📁 Choose File</label>
                            <span class="file-name-display" style="font-size: 12px; color: var(--text2);">No file chosen</span>
                            <input type="file" id="upload-file" hidden>
                        </div>
                        <button id="upload-btn" class="btn btn-primary">Share Material</button>
                    </div>
                </div>

                <!-- My Shared Materials History -->
                <div class="card-header" style="margin-bottom: -10px; margin-top: 10px;">
                    <div class="card-title">📖 My Shared Materials History</div>
                </div>
                
                <div id="feed-container">
                    <!-- My shared materials history will appear here -->
                </div>
            </div>
        </main>
    </div>
<div id="custom-modal" class="modal-overlay" style="display: none;">
    <div class="modal-content card">
        <h3 class="card-title">Notification</h3>
        <p id="modal-message" style="color: var(--text2); font-size: 13px; margin-bottom: 20px;"></p>
        <button id="close-modal-btn" class="btn btn-primary">OK</button>
    </div>
</div>
    <script>
        window.currentUser = {
            id: '<%= user ? user._id : "" %>',
            name: '<%= user ? user.name : "" %>',
            major: '<%= user ? user.major : "" %>',
            academic_year: '<%= user ? user.academic_year : "" %>',
            username: '<%= user ? user.username : "" %>'
        };
    </script>
    <script src="/js/users.js"></script>
    <script src="/js/sharedMaterials.js"></script>
</body>
</html>